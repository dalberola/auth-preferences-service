# Copy to .env before running `docker compose up`.
NODE_ENV=development
PORT=4000
# Express `trust proxy`: hop count of proxies in front of the app (1 = one LB),
# or false (no proxy) / true (trust all) / preset / comma-separated IP list.
TRUST_PROXY=1

# Overridden by docker-compose to point at the `mariadb` service; these are for host runs.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=auth_preferences

# Generate with: openssl rand -hex 32   (must be >= 32 chars)
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars

# Access token lifetime (zeit/ms format) and refresh lifetime in days.
ACCESS_TTL=15m
REFRESH_TTL_DAYS=14
# Per-account login lockout: lock after N consecutive failures, for M minutes.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
# How often the background reaper deletes expired tokens (minutes).
REAP_INTERVAL_MINUTES=60
# Refresh-token delivery: "cookie" (httpOnly cookie, same-origin web) or
# "body" (JSON body, for cross-origin / browser-extension clients).
REFRESH_TOKEN_TRANSPORT=cookie

# SMTP. docker-compose points host/port at the Mailpit container (no auth needed).
SMTP_HOST=localhost
SMTP_PORT=1025
# Implicit TLS (SMTPS, port 465). Leave false for STARTTLS (587/25) and Mailpit.
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Auth Service <no-reply@example.com>"

# Base URL of THIS service (used to build the verification link in emails).
APP_URL=http://localhost:4000
# Web client origin (CORS allowlist + post-verification redirect).
CLIENT_URL=http://localhost:3000
